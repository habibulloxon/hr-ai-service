# Copy to .env and fill in values. Do NOT commit the real .env.

# Required
OPENAI_API_KEY=

# HTTP server
PORT=8080

# OpenAI
OPENAI_MODEL=gpt-4.1-mini
OPENAI_MAX_TOKENS_TECH=500
OPENAI_MAX_TOKENS_INTERVIEW=600
OPENAI_MAX_TOKENS_FINAL=500

# Google Cloud Speech-to-Text
GCS_BUCKET=hrdev3
GCP_RECOGNIZER=projects/ewd-ai-dev/locations/us-central1/recognizers/_
SPEECH_ENDPOINT=us-central1-speech.googleapis.com:443
# Path to the GCP service-account JSON (required for /transcribe)
GOOGLE_APPLICATION_CREDENTIALS=

# Limits / timeouts
CV_MAX_BYTES=20971520
CV_DOWNLOAD_TIMEOUT=30s
TRANSCRIBE_TIMEOUT=5m
TRANSCRIBE_POLL_INTERVAL=5s
